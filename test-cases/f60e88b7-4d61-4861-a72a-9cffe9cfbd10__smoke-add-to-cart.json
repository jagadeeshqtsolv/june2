{
  "id": "smoke-add-to-cart",
  "testPlanId": "f60e88b7-4d61-4861-a72a-9cffe9cfbd10",
  "requirementId": "f5fbbcdb-1155-421e-b572-d4a794d11780",
  "suiteName": "Product Listing & Add to Cart",
  "case": {
    "id": "smoke-add-to-cart",
    "title": "Add a product to cart and verify cart icon updates",
    "priority": "P0",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "step-1",
        "action": "openUrl",
        "targetDescription": "Open application URL",
        "value": "https://www.saucedemo.com/"
      },
      {
        "id": "step-2",
        "action": "fill",
        "targetDescription": "Enter username",
        "locatorHint": "[data-test='username']",
        "value": "standard_user"
      },
      {
        "id": "step-3",
        "action": "fill",
        "targetDescription": "Enter password",
        "locatorHint": "[data-test='password']",
        "value": "secret_sauce"
      },
      {
        "id": "step-4",
        "action": "tap",
        "targetDescription": "Click login button",
        "locatorHint": "[data-test='login-button']"
      },
      {
        "id": "step-5",
        "action": "tap",
        "targetDescription": "Click Add to Cart for Sauce Labs Backpack",
        "locatorHint": "[data-test='add-to-cart-sauce-labs-backpack']"
      },
      {
        "id": "step-6",
        "action": "assertText",
        "targetDescription": "Verify cart icon shows 1 item",
        "locatorHint": ".shopping_cart_badge",
        "assertion": "1"
      }
    ],
    "tags": [
      "@smoke",
      "@regression"
    ]
  }
}
