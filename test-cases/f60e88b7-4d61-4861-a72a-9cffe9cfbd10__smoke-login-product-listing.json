{
  "id": "smoke-login-product-listing",
  "testPlanId": "f60e88b7-4d61-4861-a72a-9cffe9cfbd10",
  "requirementId": "f5fbbcdb-1155-421e-b572-d4a794d11780",
  "suiteName": "Product Listing & Add to Cart",
  "case": {
    "id": "smoke-login-product-listing",
    "title": "Login and verify product listing page loads",
    "priority": "P0",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "step-1",
        "action": "openUrl",
        "targetDescription": "Open application URL",
        "value": "https://www.saucedemo.com/"
      },
      {
        "id": "step-2",
        "action": "fill",
        "targetDescription": "Enter username",
        "locatorHint": "[data-test='username']",
        "value": "standard_user"
      },
      {
        "id": "step-3",
        "action": "fill",
        "targetDescription": "Enter password",
        "locatorHint": "[data-test='password']",
        "value": "secret_sauce"
      },
      {
        "id": "step-4",
        "action": "tap",
        "targetDescription": "Click login button",
        "locatorHint": "[data-test='login-button']"
      },
      {
        "id": "step-5",
        "action": "assertVisible",
        "targetDescription": "Verify product listing page is visible",
        "locatorHint": ".inventory_list"
      }
    ],
    "tags": [
      "@smoke",
      "@regression"
    ]
  }
}
